{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/permission-checker.cjs\"",
            "timeout": 5,
            "statusMessage": "Running permission-checker..."
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/risk-area-warning.cjs\"",
            "timeout": 5,
            "statusMessage": "Running risk-area-warning..."
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/policy-gate.cjs\"",
            "timeout": 5,
            "statusMessage": "Running policy-gate..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/security-scan.cjs\"",
            "timeout": 5,
            "statusMessage": "Running security-scan..."
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/contract-gate.cjs\"",
            "timeout": 5,
            "statusMessage": "Running contract-gate..."
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/quality-gate.cjs\"",
            "timeout": 10,
            "statusMessage": "Running quality-gate..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/teammate-idle-gate.cjs\"",
            "timeout": 5,
            "statusMessage": "Running teammate-idle-gate..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/task-completed-gate.cjs\"",
            "timeout": 5,
            "statusMessage": "Running task-completed-gate..."
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "preferences": {
    "teammateMode": "tmux"
  }
}
