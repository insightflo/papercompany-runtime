# Local-only and generated artifacts. Keep tracked runtime source in GitHub. Long-horizon docs/plans live in the sibling papercompany-artifacts repo.

# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/
*.tsbuildinfo
.vite/

# Build artifacts in server src directories (TypeScript → JS)
server/src/**/*.js
server/src/**/*.js.map
server/src/**/*.d.ts
!server/src/types/express.d.ts
server/src/**/*.d.ts.map

# npm publish build artifacts
cli/package.dev.json

# Environment variables
.env
.env.local
.env.*.local

# OS
.DS_Store

# Editor / tools
*.tmp
.vscode/
/.idea/
**/.idea/

